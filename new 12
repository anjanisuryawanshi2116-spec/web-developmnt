<?php
if ($_SERVER["REQUEST_METHOD"] == "POST") {

    // Get user input (comma-separated values)
    $input = $_POST['values'];

    // Convert string into array
    $array = explode(",", $input);

    echo "<h2>Stored Values in Array</h2>";

    // Display array values
    foreach ($array as $value) {
        echo trim($value) . "<br>";
    }

    echo "<br><a href='array_input.php'>Go Back</a>";
}
else {
?>

<!DOCTYPE html>
<html>
<head>
    <title>Array Input</title>
</head>
<body>

<h2>Enter Values (comma separated)</h2>

<form method="POST" action="">
    <input type="text" name="values" placeholder="e.g. Apple,Banana,Mango">
    <br><br>
    <input type="submit" value="Store & Display">
</form>

</body>
</html>

<?php
}
?>
