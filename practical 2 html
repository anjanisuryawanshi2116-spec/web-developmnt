<!DOCTYPE html>
<html>
<head>
    <title>Web Page Example</title>
</head>
<body>

    <h1>My Web Page</h1>

    <!-- Image -->
    <h2>Image Section</h2>
    <img src="image.jpg" alt="Sample Image" width="150" height="150">

    <!-- Hyperlink -->
    <h2>Hyperlink Section</h2>
    <p>
        Visit 
        <a href="https://www.google.com" target="_blank">Google</a>
        for more information.
    </p>

    <!-- Table with Nested Table -->
    <h2>Nested Table Section</h2>
    <table border="1" cellpadding="10">
        <tr>
            <th>Main Table Column 1</th>
            <th>Main Table Column 2</th>
        </tr>
        <tr>
            <td>Data 1</td>
            <td>
                <!-- Nested Table -->
                <table border="1" cellpadding="5">
                    <tr>
                        <th>Sub Column 1</th>
                        <th>Sub Column 2</th>
                    </tr>
                    <tr>
                        <td>Sub Data 1</td>
                        <td>Sub Data 2</td>
                    </tr>
                    <tr>
                        <td>Sub Data 3</td>
                        <td>Sub Data 4</td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>

</body>
</html>
