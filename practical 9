    <h1>👋 Welcome <?php echo $name; ?>!</h1>

    <p>This is your dynamic PHP page</p>

    <div class="time">
        🕒 Current Time:<br>
        <span id="clock"></span>
    </div>

    <button class="btn" onclick="changeName()">Change Name</button>

</div>

<script>
    // ⏰ Live clock using JavaScript
    function updateTime() {
        let now = new Date();
        document.getElementById("clock").innerHTML = now.toLocaleString();
    }

    setInterval(updateTime, 1000);
    updateTime();

    // 👤 Change name dynamically
    function changeName() {
        let user = prompt("Enter your name:");
        if (user != "") {
            document.querySelector("h1").innerHTML = "👋 Welcome " + user + "!";
        }
    }
</script>

</body>
